# Copy to .env and fill in what you have. Everything below is OPTIONAL except
# GEMINI_API_KEY (Module 3 has no keyless substitute for LLM generation — but
# Gemini's Flash/Flash-Lite tier is free, no card required).

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash  # override if Google sunsets this before your demo

# Optional upgrades / fallback tiers — pipelines run on keyless public data without these:
AQICN_TOKEN=
OPENAQ_API_KEY=
FIRMS_MAP_KEY=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
DATAGOVIN_API_KEY=
KAGGLE_USERNAME=
KAGGLE_KEY=
