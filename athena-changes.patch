+/**
+ * Module 1 — Causal Loop Detector (AQI vs public search/sentiment behaviour)
+ * Person A owns the real ingestion (AQICN/OpenAQ history, pytrends pull,
+ * PRAW Reddit scrape) and the lag correlation + HCI formula. These three
+ * mocks mirror that output shape so causal-loop.html never blocks on it.
+ */
+function mockCausalLoop(cellId) {
+  const rng = seededRandom(cellId + '-causal');
+  const aqiSeries = Array.from({ length: 7 }, () => randInt(rng, 80, 420));
+  const lagDays = randInt(rng, 1, 3); // HCI response lags the AQI spike by this many days
+  const hciSeries = aqiSeries.map((_, i) => {
+    const sourceAqi = aqiSeries[Math.max(0, i - lagDays)];
+    return Math.round((0.15 + (sourceAqi / 500) * 0.8) * 100) / 100;
+  });
+  return {
+    cellId,
+    aqiSeries,
+    hciSeries,
+    whoSafeLimit: 60, // WHO 24h PM2.5-equivalent AQI reference line
+    lagDays,
+    correlationStrength: Math.round(randFloat(rng, 0.55, 0.92) * 100) / 100,
+  };
+}
+
+const SENTIMENT_KEYWORDS = ['Breathless', 'Smog', 'Incompetence', 'Choking', 'Hazy', 'Cough', 'Mask up', 'Air purifier', 'Can\u2019t sleep'];
+function mockRedditSentiment(cellId) {
+  const rng = seededRandom(cellId + '-sentiment');
+  const changePct = -Math.round(randFloat(rng, 20, 90));
+  const label = changePct <= -70 ? 'Critical' : changePct <= -40 ? 'Negative' : changePct <= -10 ? 'Mixed' : 'Neutral';
+  return { cellId, label, changePct, keywords: sample(rng, SENTIMENT_KEYWORDS, 3) };
+}
+
+const TREND_TERMS = ['Air purifier filters', 'Asthma symptoms', 'N95 mask price', 'Leave Delhi', 'Smog today', 'Pollution mask', 'Best air quality app'];
+function mockGoogleTrends(cellId) {
+  const rng = seededRandom(cellId + '-trends');
+  const terms = sample(rng, TREND_TERMS, 3);
+  return terms.map((term) => ({ term, changePct: Math.round(randFloat(rng, 40, 480)) }));
+}
